# AI API 配置
# 复制此文件为 .env 并填入你的 API Keys
# 不需要全部配置，按需填写即可，未配置的将使用模拟数据

# ==========================================
# 国际大模型
# ==========================================

# OpenAI API Key
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Claude API Key (Anthropic)
# 获取地址：https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=your_claude_api_key_here

# Google Gemini API Key
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# 国产大模型
# ==========================================

# Kimi API Key (Moonshot)
# 获取地址：https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# 豆包 API Key (字节跳动)
# 获取地址：https://console.volcengine.com/ark/
DOUBAO_API_KEY=your_doubao_api_key_here

# 文心一言 API Key (百度)
# 获取地址：https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
WENXIN_API_KEY=your_wenxin_api_key_here
WENXIN_SECRET_KEY=your_wenxin_secret_key_here

# 通义千问 API Key (阿里云)
# 获取地址：https://dashscope.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here

# DeepSeek API Key (推荐！性价比最高)
# 获取地址：https://platform.deepseek.com/
# 注册后直接充值使用，不需要信用卡
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==========================================
# 可选：自定义 API Base URL（如果使用代理）
# ==========================================
# OPENAI_BASE_URL=https://api.openai.com/v1
# CLAUDE_BASE_URL=https://api.anthropic.com
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ==========================================
# 服务器配置
# ==========================================
PORT=3000
